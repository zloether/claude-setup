{
    "theme": "dark",
    "permissions": {
        "defaultMode": "dontAsk",
        "disableBypassPermissionsMode": "disable",
        "additionalDirectories": [],
        "allow": [
            "Read(~/.claude/projects/**/memory/**)",
            "Read(~/.claude/plans/**)",
            "Bash(git status)",
            "Bash(git diff *)",
            "Bash(git log *)",
            "Bash(git show *)",
            "Bash(git branch *)",
            "Bash(git remote)",
            "Bash(git remote -v)",
            "Bash(git remote show *)",
            "Bash(git remote get-url *)",
            "Bash(git stash list)"
        ],
        "ask": [
            "Edit(~/.claude/projects/**/memory/**)",
            "Write(~/.claude/projects/**/memory/**)",
            "Edit(~/.claude/plans/**)",
            "Write(~/.claude/plans/**)",
            "Bash(git remote set-url *)",
            "Bash(git remote add *)",
            "Bash(git remote remove *)",
            "Bash(git remote rename *)",
            "Bash(git push *)",
            "Bash(git pull *)",
            "Bash(git merge *)",
            "WebFetch",
            "Bash(chmod *)",
            "Bash(rm *)",
            "WebSearch",
            "Bash(python *.py)",
            "Bash(python3 *.py)",
            "Bash(python *)",
            "Bash(python3 *)"
        ],
        "deny": [
            "Read(~/.kube/**)",
            "Read(~/.docker/**)",
            "Read(~/.npmrc)",
            "Read(~/.netrc)",
            "Read(**/.env)",
            "Read(**/.env.*)",
            "Read(**/*.key)",
            "Read(**/*.pem)",
            "Read(**/*.p12)",
            "Read(**/*.pfx)",
            "Read(**/.ssh/**)",
            "Read(**/id_rsa*)",
            "Read(**/id_ed25519*)",
            "Read(**/.aws/**)",
            "Read(**/.config/gcloud/**)",
            "Read(**/.gnupg/**)",
            "Read(**/node_modules/**)",
            "Read(**/Desktop/**)",
            "Read(**/Documents/**)",
            "Read(**/Downloads/**)",
            "Read(~/Library/**)",
            "Read(~/.gitconfig)",
            "Read(~/.config/git/**)",
            "Read(~/.config/gh/**)",
            "Read(~/.config/op/**)",
            "Read(~/.config/doctl/**)",
            "Read(~/.config/fly/**)",
            "Read(~/.config/stripe/**)",
            "Read(~/.config/heroku/**)",
            "Read(~/.config/pypoetry/**)",
            "Read(~/.config/wakatime/**)",
            "Read(~/.config/configstore/**)",
            "Read(~/.config/helm/**)",
            "Read(~/.config/rclone/**)",
            "Read(~/.config/restic/**)",
            "Read(~/.mozilla/**)",
            "Read(~/.password-store/**)",
            "Read(~/.zsh_history)",
            "Read(~/.bash_history)",
            "Read(~/.python_history)",
            "Read(~/.node_repl_history)",
            "Read(~/.psql_history)",
            "Read(~/.mysql_history)",
            "Read(~/.lesshst)",
            "Read(~/.netlify/**)",
            "Read(~/.vercel/**)",
            "Write(**/.git/hooks/**)",
            "Write(**/.git/config)",
            "Write(**/.mcp.json)",
            "Bash(git diff --no-index *)",
            "Bash(npm install)",
            "Bash(npm install *)",
            "Bash(pip install *)",
            "Bash(npx *)",
            "Bash(npm run *)",
            "Bash(printenv *)",
            "Bash(osascript *)",
            "Bash(security *)",
            "Bash(open *)",
            "Bash(cp *)",
            "Bash(mv *)",
            "Bash(sudo *)",
            "Bash(su *)",
            "Bash(curl *)",
            "Bash(wget *)",
            "Bash(ssh *)",
            "Bash(scp *)",
            "Bash(sftp *)",
            "Bash(nc *)",
            "Bash(ncat *)",
            "Bash(rm -rf *)",
            "Bash(rm -fr *)",
            "Bash(rm -r *)",
            "Bash(rm --recursive *)",
            "Bash(mkfs *)",
            "Bash(dd *)",
            "Bash(chown *)",
            "Bash(crontab *)",
            "Bash(at *)",
            "Bash(launchctl *)",
            "Bash(systemctl *)",
            "Bash(bash -c *)",
            "Bash(sh -c *)",
            "Bash(zsh -c *)",
            "Bash(fish -c *)",
            "Bash(eval *)",
            "Bash(env *)",
            "Bash(xargs *)",
            "Bash(python -c *)",
            "Bash(python3 -c *)",
            "Bash(node -e *)",
            "Bash(perl -e *)",
            "Bash(ruby -e *)",
            "Bash(cat **/.env*)",
            "Bash(cat **/.ssh/**)",
            "Bash(cat **/.aws/**)",
            "Bash(cat **/id_rsa*)",
            "Bash(cat **/id_ed25519*)",
            "Bash(cat **/.gnupg/**)",
            "Bash(grep * **/.env*)",
            "Bash(grep * **/.ssh/**)",
            "Bash(grep * **/.aws/**)",
            "Bash(find * **/.ssh/**)",
            "Bash(find * **/.aws/**)",
            "Bash(tar * **/.ssh/**)",
            "Bash(tar * **/.aws/**)"
        ]
    },
    "sandbox": {
        "enabled": true,
        "filesystem": {
            "denyRead": [
                "~/.aws/**",
                "~/.ssh/**",
                "~/.gnupg/**",
                "~/.config/gcloud/**",
                "~/.config/op/**",
                "~/.config/doctl/**",
                "~/.config/fly/**",
                "~/.config/stripe/**",
                "~/.config/heroku/**",
                "~/.config/pypoetry/**",
                "~/.config/wakatime/**",
                "~/.config/configstore/**",
                "~/.config/helm/**",
                "~/.config/rclone/**",
                "~/.config/restic/**",
                "~/.kube/**",
                "~/.docker/**",
                "~/.npmrc",
                "~/.netrc",
                "~/.mozilla/**",
                "~/.python_history",
                "~/.node_repl_history",
                "~/.psql_history",
                "~/.mysql_history",
                "~/.lesshst"
            ]
        }
    },
    "cleanupPeriodDays": 7,
    "includeCoAuthoredBy": false,
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "autoUpdatesChannel": "stable"
}
