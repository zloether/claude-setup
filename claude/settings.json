{
    "theme": "dark",
    "permissions": {
        "defaultMode": "default",
        "disableBypassPermissionsMode": "disable",
        "additionalDirectories": [],
        "allow": [
            "Bash(git status)",
            "Bash(git diff *)",
            "Bash(git log *)",
            "Bash(git show *)",
            "Bash(git branch *)",
            "Bash(git remote *)",
            "Bash(git stash list)",
            "Bash(git add *)",
            "Bash(git commit *)",
            "Bash(python *.py)",
            "Bash(python3 *.py)"
        ],
        "ask": [
            "Bash(git push *)",
            "Bash(git pull *)",
            "Bash(git merge *)",
            "Bash(npm install)",
            "Bash(pip install *)",
            "WebFetch",
            "Bash(chmod *)",
            "Bash(rm *)",
            "WebSearch",
            "Bash(npx *)",
            "Bash(python *)",
            "Bash(python3 *)",
            "Bash(npm run *)"
        ],
        "deny": [
            "Read",
            "Edit",
            "Write",
            "Read(**/.env)",
            "Read(**/.env.*)",
            "Read(**/*.key)",
            "Read(**/*.pem)",
            "Read(**/*.p12)",
            "Read(**/*.pfx)",
            "Read(**/.ssh/**)",
            "Read(**/id_rsa*)",
            "Read(**/id_ed25519*)",
            "Read(**/.aws/**)",
            "Read(**/.config/gcloud/**)",
            "Read(**/.gnupg/**)",
            "Read(**/node_modules/**)",
            "Read(**/Desktop/**)",
            "Read(**/Documents/**)",
            "Read(**/Downloads/**)",
            "Write(**/.git/hooks/**)",
            "Write(**/.git/config)",
            "Write(**/.mcp.json)",
            "Bash(sudo *)",
            "Bash(su *)",
            "Bash(curl *)",
            "Bash(wget *)",
            "Bash(ssh *)",
            "Bash(scp *)",
            "Bash(sftp *)",
            "Bash(nc *)",
            "Bash(ncat *)",
            "Bash(rm -rf *)",
            "Bash(rm -fr *)",
            "Bash(rm -r *)",
            "Bash(rm --recursive *)",
            "Bash(mkfs *)",
            "Bash(dd *)",
            "Bash(chown *)",
            "Bash(crontab *)",
            "Bash(at *)",
            "Bash(launchctl *)",
            "Bash(systemctl *)",
            "Bash(bash -c *)",
            "Bash(sh -c *)",
            "Bash(zsh -c *)",
            "Bash(fish -c *)",
            "Bash(eval *)",
            "Bash(env *)",
            "Bash(xargs *)",
            "Bash(python -c *)",
            "Bash(python3 -c *)",
            "Bash(node -e *)",
            "Bash(perl -e *)",
            "Bash(ruby -e *)",
            "Bash(cat **/.env*)",
            "Bash(cat **/.ssh/**)",
            "Bash(cat **/.aws/**)",
            "Bash(cat **/id_rsa*)",
            "Bash(cat **/id_ed25519*)",
            "Bash(cat **/.gnupg/**)",
            "Bash(grep * **/.env*)",
            "Bash(grep * **/.ssh/**)",
            "Bash(grep * **/.aws/**)",
            "Bash(find * **/.ssh/**)",
            "Bash(find * **/.aws/**)",
            "Bash(tar * **/.ssh/**)",
            "Bash(tar * **/.aws/**)"
        ]
    },
    "sandbox": {
        "enabled": true,
        "filesystem": {
            "denyRead": [
                "~/.aws/**",
                "~/.ssh/**",
                "~/.gnupg/**",
                "~/.config/gcloud/**"
            ]
        }
    },
    "cleanupPeriodDays": 7,
    "includeCoAuthoredBy": false,
    "statusLine": {
        "type": "command",
        "command": "~/.claude/statusline-command.sh",
        "refreshIntervalMs": 5000
    },
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "autoUpdatesChannel": "stable"
}
