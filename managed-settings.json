{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "allowManagedHooksOnly": true,
  "disableSkillShellExecution": true,
  "statusLine": {
    "type": "command",
    "command": "/usr/local/bin/claude-statusline",
    "refreshIntervalMs": 5000
  },
  "disableBypassPermissionsMode": "disable",
  "cleanupPeriodDays": 7,

  "sandbox": {
    "enabled": true,
    "filesystem": {
      "denyRead": [
        "~/.aws/**",
        "~/.ssh/**",
        "~/.gnupg/**",
        "~/.config/gcloud/**",
        "~/.config/op/**",
        "~/.config/doctl/**",
        "~/.config/fly/**",
        "~/.config/stripe/**",
        "~/.config/heroku/**",
        "~/.config/pypoetry/**",
        "~/.config/wakatime/**",
        "~/.config/configstore/**",
        "~/.config/helm/**",
        "~/.config/rclone/**",
        "~/.config/restic/**",
        "~/Library/**",
        "~/.password-store/**",
        "~/.kube/**",
        "~/.docker/**",
        "~/.npmrc",
        "~/.netrc",
        "~/.mozilla/**",
        "~/.zsh_history",
        "~/.bash_history",
        "~/.python_history",
        "~/.node_repl_history",
        "~/.psql_history",
        "~/.mysql_history",
        "~/.lesshst"
      ]
    },
    "network": {
      "allowedDomains": []
    }
  },

  "permissions": {
    "deny": [
      "Read(~/Library/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.config/op/**)",
      "Read(~/.config/doctl/**)",
      "Read(~/.config/fly/**)",
      "Read(~/.config/stripe/**)",
      "Read(~/.config/heroku/**)",
      "Read(~/.config/pypoetry/**)",
      "Read(~/.config/wakatime/**)",
      "Read(~/.config/configstore/**)",
      "Read(~/.config/helm/**)",
      "Read(~/.config/rclone/**)",
      "Read(~/.config/restic/**)",
      "Read(~/.password-store/**)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.kube/**)",
      "Read(~/.docker/**)",
      "Read(~/.npmrc)",
      "Read(~/.netrc)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(~/.netlify/**)",
      "Read(~/.vercel/**)",
      "Read(~/.zsh_history)",
      "Read(~/.bash_history)",
      "Bash(git diff --no-index *)",
      "Bash(printenv *)",
      "Bash(osascript *)",
      "Bash(security *)",
      "Bash(open *)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(sftp *)",
      "Bash(nc *)",
      "Bash(ncat *)",
      "Bash(bash -c *)",
      "Bash(sh -c *)",
      "Bash(zsh -c *)",
      "Bash(fish -c *)",
      "Bash(eval *)",
      "Bash(env *)",
      "Bash(xargs *)",
      "Bash(python -c *)",
      "Bash(python3 -c *)",
      "Bash(node -e *)",
      "Bash(perl -e *)",
      "Bash(ruby -e *)",
      "Bash(rm -r *)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm --recursive *)",
      "Bash(mkfs *)",
      "Bash(dd *)",
      "Bash(chown *)",
      "Bash(crontab *)",
      "Bash(at *)",
      "Bash(launchctl *)",
      "Bash(systemctl *)",
      "Bash(cat **/.env*)",
      "Bash(cat **/.ssh/**)",
      "Bash(cat **/.aws/**)",
      "Bash(cat **/id_rsa*)",
      "Bash(cat **/id_ed25519*)",
      "Bash(cat **/.gnupg/**)",
      "Bash(grep * **/.env*)",
      "Bash(grep * **/.ssh/**)",
      "Bash(grep * **/.aws/**)",
      "Bash(find * **/.ssh/**)",
      "Bash(find * **/.aws/**)",
      "Bash(tar * **/.ssh/**)",
      "Bash(tar * **/.aws/**)",
      "Write(**/.git/hooks/**)",
      "Write(**/.git/config)",
      "Write(**/.mcp.json)"
    ]
  }
}
